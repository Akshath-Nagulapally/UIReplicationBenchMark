{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
      "openrouter": {
        "env": ["OPENROUTER_API_KEY"],
        "npm": "@ai-sdk/openai-compatible",
        "name": "OpenRouter",
        "models": {
          "qwen/qwen3.6-27b": {
            "name": "Qwen3.6 27B",
            "attachment": true,
            "reasoning": true,
            "temperature": true,
            "tool_call": true,
            "modalities": {
              "input": ["text", "image"],
              "output": ["text"]
            },
            "cost": {
              "input": 0.325,
              "output": 3.25
            },
            "limit": {
              "context": 262144,
              "output": 81920
            }
          }
        },
        "options": {
          "baseURL": "https://openrouter.ai/api/v1",
          "apiKey": "{env:OPENROUTER_API_KEY}",
          "timeout": false,
          "chunkTimeout": 120000
        }
      }
  },
    "model": "openrouter/qwen/qwen3.6-27b",
    "permission": {
      "question": "deny"
    }
  }
